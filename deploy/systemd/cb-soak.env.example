# Environment file for the cb-soak systemd service.
# Copy to /etc/cb-soak.env, fill in, and lock it down:  sudo chmod 600 /etc/cb-soak.env
# These override the connection settings in config.yaml.

COUCHBASE_CONNSTR=couchbase://10.0.0.10
COUCHBASE_USERNAME=Administrator
COUCHBASE_PASSWORD=change-me
# Optional overrides:
# COUCHBASE_BUCKET=soak
# COUCHBASE_SCOPE=_default
# COUCHBASE_COLLECTION=_default
